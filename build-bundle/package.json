  "name": "powersync",
  "description": "A CLI for managing PowerSync instances",
  "version": "0.0.0",
  "author": "POWERSYNC",
  "bin": {
    "powersync": "./bin/run.js"
  },
  "scripts": {
    "dev": "tsx bin/dev.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc -b && pnpm prepack",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "pnpm run lint",
    "pretest": "pnpm run build",
    "readme:generate": "oclif readme && pnpm exec prettier --write README.md",
    "prepack": "oclif manifest && pnpm run readme:generate",
    "test": "vitest",
    "version": "pnpm run readme:generate && git add README.md"
  },
